generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String   @default("123")
  role           String   @default("MEMBRO") // MEMBRO, VOLUNTARIO, AUXILIAR_LIDER, LIDER, ADMIN
  campus         String   @default("Zion Ribeirão Preto")
  points         Int      @default(0)
  bibleStreak    Int      @default(0)
  canRedeem      Boolean  @default(false) // liberação da liderança para resgatar prêmios na loja
  welcomed       Boolean  @default(false) // já viu o pop-up de boas-vindas no primeiro acesso
  profileImage   String? // CAMPO NOVO: Foto de Perfil (Base64 ou URL)
  // Acesso administrativo granular por módulo (independe do cargo — ex.: um Líder pode
  // gerenciar a Loja sem virar Admin/Pastor). Concedido em Admin > Membros.
  canManageLinks Boolean  @default(false)
  canManageAreas Boolean  @default(false)
  canManageStore Boolean  @default(false)
  prayerAccess   Boolean  @default(false) // acesso individual liberado (Admin > Membros) aos pedidos de oração
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  linkParticipations  LinkParticipation[]
  areaParticipations  AreaParticipation[]
  shifts              Shift[]
  messages            LinkMessage[]
  publications        Publication[]
  redemptions         Redemption[]
  readingLogs         ReadingLog[]
  pointAwards         PointAward[]
  ownedGroups         ReadingGroup[]       @relation("GroupOwner")
  groupMemberships    GroupMember[]
  notifications       Notification[]
  groupMessages       GroupMessage[]
  bugReports          BugReport[]
  prayerRequests      PrayerRequest[]
  areaMessages        AreaMessage[]
  eventParticipations EventParticipation[]
  availabilities      Availability[]
  trainingCompletions AreaTrainingCompletion[]

  ledLinks Link[] @relation("LinkLeader")
  ledAreas Area[] @relation("AreaLeader")
}

model Notification {
  id        String   @id @default(uuid())
  type      String // INFO, REQUEST, APPROVED, REJECTED, MILESTONE, REMINDER
  title     String
  body      String?
  refId     String? // dedupe/deep-link (ex: reminder-182)
  route     String? // destino ao clicar (ex: "membros:reading", "voluntarios", "links", "membros:groups")
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// Ledger de pontos: garante que cada ação credite pontos apenas uma vez
model PointAward {
  id        String   @id @default(uuid())
  ruleKey   String // ex: EVENT_PARTICIPATION
  refId     String // id da ação (evento, escala, treinamento...)
  points    Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, ruleKey, refId])
}

model ReadingGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation("GroupOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())

  members  GroupMember[]
  messages GroupMessage[]
}

model GroupMessage {
  id        String       @id @default(uuid())
  type      String       @default("COMMENT") // READING (atividade automática), COMMENT
  content   String // texto do comentário OU referência da leitura
  imageUrl  String? // foto da leitura (quando type READING com foto)
  groupId   String
  group     ReadingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  reactions MessageReaction[]

  @@index([groupId, createdAt])
}

model MessageReaction {
  id        String       @id @default(uuid())
  emoji     String
  userId    String // sem relação de volta em User (apenas referência)
  messageId String
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([messageId, userId, emoji])
}

model GroupMember {
  id        String       @id @default(uuid())
  status    String       @default("ATIVO") // ATIVO, PENDENTE (convite não aceito)
  groupId   String
  group     ReadingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([groupId, userId])
}

model ReadingLog {
  id        String   @id @default(uuid())
  day       Int // dia do plano (1..365)
  reference String // leitura do dia, ex: "Gênesis 1-3"
  photoUrl  String // foto de comprovação (Base64)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, day])
}

// Plano de leitura bíblica editável por ano (Admin > Plano Bíblico). O plano usado no dia a dia
// é o que corresponde ao ano corrente; se não houver um configurado, cai no dataset padrão.
model ReadingPlan {
  id         String   @id @default(uuid())
  year       Int      @unique
  label      String // ex: "Plano Bíblico 2026"
  days       Json // array de strings, 1 referência por dia (índice 0 = dia 1)
  spotifyUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Permissões por cargo (matriz configurável no Admin > Cargos)
model RolePermission {
  id      String  @id @default(uuid())
  role    String // MEMBRO, VOLUNTARIO, AUXILIAR, LIDER, ADMIN
  permKey String // ex: STORE_REDEEM, VOUCHER_VALIDATE
  allowed Boolean @default(false)

  @@unique([role, permKey])
}

model BugReport {
  id          String   @id @default(uuid())
  type        String   @default("BUG") // BUG, SUGESTAO
  title       String
  description String
  status      String   @default("ABERTO") // ABERTO, RESOLVIDO
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model PrayerRequest {
  id        String   @id @default(uuid())
  content   String
  status    String   @default("ATIVO") // ATIVO, ORADO
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model PointRule {
  id          String   @id @default(uuid())
  key         String   @unique // identificador da ação, ex: EVENT_PARTICIPATION
  label       String
  description String?
  category    String   @default("Geral")
  points      Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("Geral")
  description String?
  cost        Int // Zion Points necessários para resgatar
  imageUrl    String? // foto (Base64 ou URL)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions Redemption[]
}

model Redemption {
  id          String    @id @default(uuid())
  code        String    @unique
  cost        Int
  status      String    @default("ATIVO") // ATIVO, USADO
  productName String // snapshot do nome no momento do resgate
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())
  usedAt      DateTime?
}

model Publication {
  id          String   @id @default(uuid())
  content     String
  imageUrl    String?
  documentUrl String?
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Link {
  id          String   @id @default(uuid())
  name        String
  day         String
  time        String
  isOnline    Boolean  @default(false)
  locationUrl String?
  description String?
  leaderId    String
  leader      User     @relation("LinkLeader", fields: [leaderId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participations LinkParticipation[]
  messages       LinkMessage[]
}

model LinkMessage {
  id          String   @id @default(uuid())
  content     String
  category    String   @default("RESUMO")
  isPinned    Boolean  @default(false)
  pollOptions String? // JSON de opções quando é enquete (ex: ["Sim","Não"])
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  linkId      String
  link        Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reactions LinkMessageReaction[]
  votes     PollVote[]
}

model LinkMessageReaction {
  id        String      @id @default(uuid())
  emoji     String
  userId    String
  messageId String
  message   LinkMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
}

model PollVote {
  id          String      @id @default(uuid())
  optionIndex Int
  userId      String
  messageId   String
  message     LinkMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@unique([messageId, userId])
}

model LinkParticipation {
  id        String   @id @default(uuid())
  status    String   @default("PENDENTE")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, linkId])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  location    String?
  type        String   @default("GERAL")
  recurrence  String   @default("NONE") // NONE, WEEKLY, MONTHLY
  checkinCode String   @default("") // código para check-in via QR
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participations EventParticipation[]
}

// Confirmação de presença (RSVP) e check-in real, separados — permite ao admin contar os dois.
model EventParticipation {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  refId       String // evento ou ocorrência (eventId ou eventId@isoDate) — chave de idempotência
  rsvpAt      DateTime  @default(now())
  checkedInAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, refId])
  @@index([eventId])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String   @default("GERAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Area {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String   @default("Briefcase") // nome do ícone lucide-react (catálogo fixo no frontend)
  leaderId    String
  leader      User     @relation("AreaLeader", fields: [leaderId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participations AreaParticipation[]
  shifts         Shift[]
  messages       AreaMessage[]
  positions      AreaPosition[]
  availabilities Availability[]
  trainings      AreaTraining[]
}

// Posições dentro de uma área (ex.: Keola Coffee -> Balcão, Forno, Barista). Só o líder cria.
model AreaPosition {
  id                 String        @id @default(uuid())
  name               String
  order              Int           @default(0)
  areaId             String
  area               Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  requiredTrainingId String?
  requiredTraining   AreaTraining? @relation(fields: [requiredTrainingId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())

  shifts Shift[]

  @@unique([areaId, name])
}

// Treinamento/curso de uma área (módulo): vídeo, foto e/ou link, exibido aos voluntários.
// Uma posição pode exigir a conclusão de um treinamento antes de a pessoa ser escalada nela.
model AreaTraining {
  id          String   @id @default(uuid())
  areaId      String
  area        Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  title       String
  description String?
  videoUrl    String?
  imageUrl    String?
  linkUrl     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  completions AreaTrainingCompletion[]
  positions   AreaPosition[]
}

model AreaTrainingCompletion {
  id          String       @id @default(uuid())
  trainingId  String
  training    AreaTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  completedAt DateTime     @default(now())

  @@unique([trainingId, userId])
}

// Disponibilidade semanal do voluntário para uma área (dia da semana + período).
model Availability {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  areaId    String
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  weekday   Int // 0=domingo ... 6=sábado
  period    String // MANHA, TARDE, NOITE
  createdAt DateTime @default(now())

  @@unique([userId, areaId, weekday, period])
}

model AreaMessage {
  id          String   @id @default(uuid())
  content     String
  category    String   @default("AVISO")
  isPinned    Boolean  @default(false)
  pollOptions String? // JSON de opções quando é enquete
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  areaId      String
  area        Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reactions AreaMessageReaction[]
  votes     AreaPollVote[]
}

model AreaMessageReaction {
  id        String      @id @default(uuid())
  emoji     String
  userId    String
  messageId String
  message   AreaMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
}

model AreaPollVote {
  id          String      @id @default(uuid())
  optionIndex Int
  userId      String
  messageId   String
  message     AreaMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@unique([messageId, userId])
}

model AreaParticipation {
  id        String   @id @default(uuid())
  status    String   @default("PENDENTE")
  role      String   @default("Voluntário")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  areaId    String
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, areaId])
}

model Shift {
  id         String @id @default(uuid())
  department String

  date        DateTime
  status      String        @default("Pendente")
  volunteerId String?
  user        User?         @relation(fields: [volunteerId], references: [id])
  areaId      String?
  area        Area?         @relation(fields: [areaId], references: [id])
  positionId  String?
  position    AreaPosition? @relation(fields: [positionId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
