# Backend — variáveis de ambiente (copie para .env em produção/local)

# Banco de dados. Em produção use PostgreSQL (ex.: Neon):
# DATABASE_URL="postgresql://usuario:senha@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# Porta (Render define automaticamente via PORT)
PORT=3000

# Segredo dos tokens JWT — TROQUE por um valor aleatório longo em produção
JWT_SECRET="troque-por-um-segredo-aleatorio-bem-grande"

# Chave exigida para rodar /api/seed
SEED_KEY="zion-dev-seed"

# Origens permitidas (CORS), separadas por vírgula. Em produção, a URL do frontend:
# CORS_ORIGIN="https://zionapp.vercel.app"
