# Frontend — variáveis de ambiente (Vite; prefixo VITE_)

# URL pública da API (backend no Render). Em produção, defina na Vercel:
# VITE_API_URL="https://zion-backend.onrender.com"

# Se vazio, a URL é derivada do host acessado (mesmo hostname, porta abaixo) — bom para dev local.
VITE_API_PORT=3000
